                "authentication": "predefinedCredentialType",
                "nodeCredentialType": "googleSheetsOAuth2Api",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"requests\": [\n    {\n      \"updateSheetProperties\": {\n        \"properties\": {\n          \"sheetId\": {{ $json.sheetId }},\n          \"title\": \"{{ $node.設定參數.json.new_sheet_name }}\",\n          \"index\": 3,\n          \"hidden\": false\n        },\n        \"fields\": \"title,index,hidden\"\n      }\n    }\n  ]\n}",
