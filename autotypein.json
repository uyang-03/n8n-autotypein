            "name": "新增tab",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                480,
                -32
            ],
            "id": "d5bb4112-f953-4ecd-8715-4020be878dcb",
            "credentials": {
                "googleSheetsOAuth2Api": {
                    "id": "QDgBdmnsKlu9ijRH",
                    "name": "Google Sheets account"
                }
            },
            "notes": "改名並移動到 Index 3 (第4順位)"
        },
        {
            "parameters": {
                "jsCode": "/* \n * \u4fee\u6b63\u7248\u908f\u8輯\uff1a\n * \u539f\u672c\u53ea\u6293\u300c\u672c\u9031\u4e00\u300d\u7576\u5929\u7684\u6587\u7ae0\u3002\n * \u6539\u70ba\u6293\u53d6\u300c\u672c\u9031\u4e00 00:00\u300d\u5230\u300c\u4e0b\u9031\u4e00 00:00\u300d\u4e4b\u9593\u7684\u6240\u6709\u6587\u7ae0\u3002\n * \u4e5f\u5c31\u662f\u672c\u9031\u4e00\u5230\u9031\u65e5\u7684\u65b0\u6587\u7ae0\u90fd\u6703\u88ab\u4fdd\u7559\u3002\n */\n\nconst items = $input.all();\nif (items.length === 0 || !items[0].json.data) {\n  return [];\n}\nconst html = items[0].json.data;\n\n// 1. \u8a08\u7b97\u672c\u9031\u4e00\u8207\u4e0b\u9031\u4e00\u7684\u65e5\u671f\u754c\u7dda\nconst now = new Date();\nconst currentDay = now.getDay(); // 0(Sun) ~ 6(Sat)\n// \u8a08\u7b97\u56de\u5230\u672c\u9031\u4e00\u7684\u5dee\u8ddd\n// \u5982\u679c\u4eca\u5929\u662f\u9031\u65e5(0)\uff0c\u8981\u6e1b6\u5929\u56de\u5230\u9031\u4e00\uff1b\u5982\u679c\u4eca\u5929\u662f\u9031\u4e00(1)\uff0c\u6e1b0\u5929\uff1b\u5982\u679c\u4eca\u5929\u662f\u9031\u4e8c(2)\uff0c\u6e1b1\u5929...\nconst diffToMonday = currentDay === 0 ? -6 : 1 - currentDay;\n\n// \u8a2d\u5b9a\u672c\u9031\u4e00 (00:00:00)\nconst mondayDate = new Date(now);\nmondayDate.setDate(now.getDate() + diffToMonday);\nmondayDate.setHours(0, 0, 0, 0);\n\n// \u8a2d\u5b9a\u4e0b\u9031\u4e00 (\u4f5c\u70ba\u7d50\u675f\u754c\u7dda)\nconst nextMondayDate = new Date(mondayDate);\nnextMondayDate.setDate(mondayDate.getDate() + 7);\n\nconst articles = [];\nconst rawItems = html.split('<div class=\"result_item\">');\n\n// 2. \u5b9a\u7fa9\u589e\u5f37\u7248 Regex (\u4e0d\u9650\u5c6c\u6027\u9806\u5e8f)\nconst titleRegex = /<h2>(.*?)<\\/h2>/;\nconst linkTagRegex = /<a[^>]+class=\"item_cover\"[^>]*>/; \nconst hrefRefex = /href=\"([^\\\"]+)\"/;\nconst dateRegex = /class=\"item_date\">(.*?)<\\/div>/;\nconst categoryRegex = /class=\"item_type\"[^>]*>(.*?)<\\/a>/;\n\n// 3. \u904d\u6b77\u6240\u6709\u6587\u7ae0\nfor (let i = 1; i < rawItems.length; i++) {\n  const itemHtml = rawItems[i];\n  \n  const titleMatch = itemHtml.match(titleRegex);\n  const dateMatch = itemHtml.match(dateRegex);\n  const categoryMatch = itemHtml.match(categoryRegex);\n  \n  // \u89e3\u6790\u9023\u7d50\n  let link = null;\n  const linkTagMatch = itemHtml.match(linkTagRegex);\n  if (linkTagMatch) {\n     const hrefMatch = linkTagMatch[0].match(hrefRefex);\n     if (hrefMatch) link = hrefMatch[1];\n  }\n\n  // \u78ba\u4fdd\u6240\u6709\u6b04\u4f4d\u90fd\u6293\u5230\u4e86\n  if (titleMatch && link && dateMatch && categoryMatch) {\n    const title = titleMatch[1].trim();\n    const dateStr = dateMatch[1].trim(); // \u4f8b\u5982 \"2023-10-25\"\n    const category = categoryMatch[1].trim();\n    \n    // \u89e3\u6790\u6587\u7ae0\u65e5\u671f\u53ef\u4ee5\u6bd4\u8f03\u7684\u6642\u9593\u683c\u5f0f\n    // \u5047\u8a2d dateStr \u683c\u5f0f\u56fa\u5b9a\u70ba YYYY-MM-DD\n    const parts = dateStr.split('-');\n    if (parts.length === 3) {\n        // new Date(y, m-1, d)\n        const articleDate = new Date(\n            parseInt(parts[0], 10), \n            parseInt(parts[1], 10) - 1, \n            parseInt(parts[2], 10)\n        );\n        \n        // 4. \u3010\u95dc\u9375\u904e\u6ffe\u3011\u6539\u70ba\u8303\u570d\u5224\u65b7\uff1a >= \u672c\u9031\u4e00 \u4e14 < \u4e0b\u9031\u4e00\n        if (articleDate >= mondayDate && articleDate < nextMondayDate) {\n            \n            let brand = '\u5176\u4ed6';\n            if (category === '\u6d88\u8cbb\u8005\u6d1e\u5bdf') brand = 'iBuzz(\u6d88\u8cbb\u8005\u6d1e\u5bdf)';\n            else if (category === '\u7db2\u7d05\u884c\u92b7\u7b56\u7565') brand = 'Asia KOL';\n            else if (category === '\u6578\u64da\u5206\u6790\u89e3\u65b9') brand = '\u696d\u52d9\u63d0\u4f9b';\n            else if (category === '\u793e\u7fa4\u7c89\u7d72\u5718\u5065\u6aa2') brand = 'Fans Feed';\n\n            const full_link = link.startsWith('http') ? link : 'https://www.i-buzz.com.tw' + link;\n\n            articles.push({\n              json: {\n                title: title,\n                date: dateStr,\n                brand: brand,\n                full_link: full_link\n              }\n            });\n        }\n    }\n  }\n}\n\nreturn articles;"
            },
